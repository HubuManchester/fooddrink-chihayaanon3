<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.JournalListPage"
             xmlns:viewmodel="clr-namespace:TasteNote.ViewModels"
             xmlns:converter="clr-namespace:TasteNote.Converters"
             x:DataType="viewmodel:JournalListViewModel"
             Title="品鉴日记"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converter:StringToUriConverter x:Key="StringToUriConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="0">

        <!-- Search Bar with Voice Button -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="16,12,12,0"
              ColumnSpacing="8">
            <Frame Grid.Column="0"
                   BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource PrimaryLight}"
                   CornerRadius="12"
                   Padding="0"
                   HasShadow="False"
                   HeightRequest="44">
                <Grid ColumnDefinitions="Auto,*"
                      Padding="12,0">
                    <Label Text="🔍"
                           FontSize="16"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Text="{Binding SearchText}"
                           Placeholder="搜索品鉴记录..."
                           FontSize="14"
                           BackgroundColor="Transparent"
                           ReturnCommand="{Binding SearchCommand}"
                           AutomationId="SearchEntry"
                           SemanticProperties.Hint="搜索品鉴记录" />
                </Grid>
            </Frame>
            <Button Grid.Column="1"
                    Text="🎤"
                    FontSize="20"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="22"
                    Padding="0"
                    BackgroundColor="{StaticResource PrimaryLight}"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding VoiceSearchCommand}"
                    AutomationId="VoiceSearchButton"
                    SemanticProperties.Hint="语音搜索" />
        </Grid>

        <!-- Category Filter -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="16,12,16,0">
            <HorizontalStackLayout Spacing="8"
                                   BindableLayout.ItemsSource="{Binding Categories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="{x:Null}">
                        <Button Text="{Binding .}"
                                FontSize="13"
                                Padding="16,8"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                TextColor="{StaticResource Primary}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:JournalListViewModel}}, Path=SelectCategoryCommand}"
                                CommandParameter="{Binding .}"
                                AutomationId="CategoryButton" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Journal List -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadRecordsCommand}"
                     IsRefreshing="{Binding IsRefreshing}"
                     Margin="0,8,0,0">
            <CollectionView x:Name="JournalListView"
                            ItemsSource="{Binding JournalRecords}"
                            SelectionMode="None"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                            Margin="16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="{x:Null}">
                        <SwipeView Margin="0,0,0,12">
                            <!-- Swipe Right-to-Left reveals Delete -->
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItem Text="删除"
                                               BackgroundColor="{StaticResource Accent}"
                                               IconImageSource="delete.png"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:JournalListViewModel}}, Path=DeleteRecordCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <!-- Card Content -->
                            <Border BackgroundColor="{StaticResource Surface}"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    Padding="14">
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource TextSecondary}"
                                            Offset="0,3"
                                            Radius="10"
                                            Opacity="0.1" />
                                </Border.Shadow>

                                <Grid RowDefinitions="Auto"
                                      ColumnDefinitions="80,*,Auto"
                                      ColumnSpacing="12">

                                    <!-- Image -->
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 10"
                                            BackgroundColor="{StaticResource PrimaryLight}"
                                            WidthRequest="80"
                                            HeightRequest="80"
                                            HorizontalOptions="Start"
                                            VerticalOptions="Start">
                                        <Image Source="{Binding ImagePath, Converter={StaticResource StringToUriConverter}}"
                                               Aspect="AspectFill"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill" />
                                    </Border>

                                    <!-- Center Info -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4"
                                                         VerticalOptions="Start">
                                        <Label Text="{Binding Title}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding LocationName}"
                                               FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:yyyy-MM-dd}'}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Border BackgroundColor="{StaticResource PrimaryLight}"
                                                StrokeShape="RoundRectangle 8"
                                                HorizontalOptions="Start"
                                                Padding="6,2">
                                            <Label Text="{Binding Category}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Primary}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <!-- Right: Rating + Favorite -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="6"
                                                         HorizontalOptions="End"
                                                         VerticalOptions="Start">
                                        <Label FontSize="14"
                                               HorizontalOptions="End">
                                            <Label.Text>
                                                <Binding Path="Rating"
                                                         StringFormat="⭐ {0}" />
                                            </Label.Text>
                                        </Label>
                                        <Label Text="❤️"
                                               FontSize="20"
                                               HorizontalOptions="End"
                                               IsVisible="{Binding IsFavorite}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:JournalListViewModel}}, Path=GoToDetailCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Bottom Record Button -->
        <Border Grid.Row="3"
                BackgroundColor="{StaticResource Background}"
                Padding="20,12,20,20"
                HorizontalOptions="Fill">
            <Button x:Name="RecordButton"
                    Text="+ 记录品鉴"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="{StaticResource Surface}"
                    BackgroundColor="{StaticResource Primary}"
                    CornerRadius="25"
                    HeightRequest="50"
                    Command="{Binding NewRecordCommand}"
                    AutomationId="RecordButton"
                    SemanticProperties.Hint="开始记录新的品鉴" />
        </Border>
    </Grid>
</ContentPage>
