<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.ProfilePage"
             xmlns:viewmodel="clr-namespace:TasteNote.ViewModels"
             x:DataType="viewmodel:ProfileViewModel"
             Title="我的"
             BackgroundColor="{StaticResource Background}">

    <ScrollView Padding="16,8"
                VerticalOptions="Fill">
        <VerticalStackLayout Spacing="16">

            <!-- User Info -->
            <VerticalStackLayout Spacing="12"
                                 HorizontalOptions="Center"
                                 Margin="0,16,0,0">
                <Border StrokeShape="RoundRectangle 40"
                        BackgroundColor="{StaticResource PrimaryLight}"
                        WidthRequest="80"
                        HeightRequest="80"
                        HorizontalOptions="Center">
                    <Label Text="👤"
                           FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <Entry Text="{Binding UserName}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalTextAlignment="Center"
                       Placeholder="输入你的名字"
                       HorizontalOptions="Center"
                       WidthRequest="250"
                       AutomationId="UserNameEntry"
                       SemanticProperties.Hint="用户名" />
            </VerticalStackLayout>

            <!-- Taste Preview Card -->
            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray200}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Gray200}"
                            Offset="0,2"
                            Radius="8"
                            Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="口味预览"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <!-- Mini Flavor Bars -->
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="32,*,32"
                          RowSpacing="4"
                          ColumnSpacing="8">
                        <Label Text="甜" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <ProgressBar Grid.Column="1" Progress="{Binding SweetScore}" ProgressColor="{StaticResource FlavorSweet}" HeightRequest="6" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="{Binding SweetScore, StringFormat='{0:F1}'}" FontSize="10" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" HorizontalOptions="End" />

                        <Label Grid.Row="1" Text="酸" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="1" Grid.Column="1" Progress="{Binding SourScore}" ProgressColor="{StaticResource FlavorSour}" HeightRequest="6" VerticalOptions="Center" />
                        <Label Grid.Row="1" Grid.Column="2" Text="{Binding SourScore, StringFormat='{0:F1}'}" FontSize="10" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" HorizontalOptions="End" />

                        <Label Grid.Row="2" Text="苦" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="2" Grid.Column="1" Progress="{Binding BitterScore}" ProgressColor="{StaticResource FlavorBitter}" HeightRequest="6" VerticalOptions="Center" />
                        <Label Grid.Row="2" Grid.Column="2" Text="{Binding BitterScore, StringFormat='{0:F1}'}" FontSize="10" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" HorizontalOptions="End" />

                        <Label Grid.Row="3" Text="咸" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="3" Grid.Column="1" Progress="{Binding SaltyScore}" ProgressColor="{StaticResource FlavorSalty}" HeightRequest="6" VerticalOptions="Center" />
                        <Label Grid.Row="3" Grid.Column="2" Text="{Binding SaltyScore, StringFormat='{0:F1}'}" FontSize="10" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" HorizontalOptions="End" />

                        <Label Grid.Row="4" Text="鲜" FontSize="12" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center" />
                        <ProgressBar Grid.Row="4" Grid.Column="1" Progress="{Binding UmamiScore}" ProgressColor="{StaticResource FlavorUmami}" HeightRequest="6" VerticalOptions="Center" />
                        <Label Grid.Row="4" Grid.Column="2" Text="{Binding UmamiScore, StringFormat='{0:F1}'}" FontSize="10" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" HorizontalOptions="End" />
                    </Grid>

                    <Button Text="查看完整档案 →"
                            FontSize="13"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            Command="{Binding NavigateTasteProfileCommand}"
                            HorizontalOptions="End"
                            Padding="0"
                            AutomationId="ViewFullProfileButton"
                            SemanticProperties.Hint="查看完整口味档案" />
                </VerticalStackLayout>
            </Border>

            <!-- Settings Section -->
            <Label Text="设置"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="0,8,0,0" />

            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray200}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Gray200}"
                            Offset="0,2"
                            Radius="6"
                            Opacity="0.25" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">

                    <!-- Theme -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="主题"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="浅色"
                                    FontSize="13" Padding="16,8"
                                    Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                    AutomationId="ThemeLightButton" />

                            <Button Text="深色"
                                    FontSize="13" Padding="16,8"
                                    Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                                    AutomationId="ThemeDarkButton" />
                            <Button Text="跟随系统"
                                    FontSize="13" Padding="16,8"
                                    Command="{Binding SetThemeCommand}" CommandParameter="System"
                                    AutomationId="ThemeSystemButton" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Font Size -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="字体大小"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="小" FontSize="13" Padding="16,8"
                                    Command="{Binding SetFontSizeCommand}" CommandParameter="Small"
                                    AutomationId="FontSmallButton" />
                            <Button Text="中" FontSize="13" Padding="16,8"
                                    Command="{Binding SetFontSizeCommand}" CommandParameter="Medium"
                                    AutomationId="FontMediumButton" />
                            <Button Text="大" FontSize="13" Padding="16,8"
                                    Command="{Binding SetFontSizeCommand}" CommandParameter="Large"
                                    AutomationId="FontLargeButton" />
                            <Button Text="超大" FontSize="13" Padding="16,8"
                                    Command="{Binding SetFontSizeCommand}" CommandParameter="ExtraLarge"
                                    AutomationId="FontExtraLargeButton" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Separator -->
                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <!-- Test Buttons -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="测试功能"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                            <Button Text="语音测试"
                                    FontSize="13"
                                    BackgroundColor="{StaticResource Gray100}"
                                    TextColor="{StaticResource TextPrimary}"
                                    Command="{Binding TestVoiceCommand}"
                                    AutomationId="TestVoiceButton"
                                    SemanticProperties.Hint="语音测试" />
                            <Button Grid.Column="1"
                                    Text="朗读测试"
                                    FontSize="13"
                                    BackgroundColor="{StaticResource Gray100}"
                                    TextColor="{StaticResource TextPrimary}"
                                    Command="{Binding TestTtsCommand}"
                                    AutomationId="TestTtsButton"
                                    SemanticProperties.Hint="朗读测试" />
                            <Button Grid.Row="1"
                                    Text="振动测试"
                                    FontSize="13"
                                    BackgroundColor="{StaticResource Gray100}"
                                    TextColor="{StaticResource TextPrimary}"
                                    Command="{Binding TestVibrationCommand}"
                                    AutomationId="TestVibrationButton"
                                    SemanticProperties.Hint="振动测试" />
                            <Button Grid.Row="1" Grid.Column="1"
                                    Text="附近店铺"
                                    FontSize="13"
                                    BackgroundColor="{StaticResource Gray100}"
                                    TextColor="{StaticResource TextPrimary}"
                                    Command="{Binding NavigateNearbyCommand}"
                                    AutomationId="NearbyButton"
                                    SemanticProperties.Hint="查看附近店铺" />
                        </Grid>

                        <Button Text="关于应用"
                                FontSize="13"
                                BackgroundColor="{StaticResource Gray100}"
                                TextColor="{StaticResource TextPrimary}"
                                Command="{Binding ShowAboutCommand}"
                                AutomationId="AboutButton"
                                SemanticProperties.Hint="关于应用" />

                        <Button Text="重置数据"
                                FontSize="13"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Accent}"
                                Command="{Binding ResetDataCommand}"
                                AutomationId="ResetDataButton"
                                SemanticProperties.Hint="重置所有数据" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- App Version -->
            <Label Text="{Binding AppVersion, StringFormat='版本 {0}'}"
                   FontSize="12"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center"
                   Margin="0,8" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
