<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.Controls.BeverageCard"
             x:Name="This">

    <Border StrokeShape="RoundRectangle 12"
            BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource Gray200}"
            Padding="0"
            Margin="0,4"
            WidthRequest="160">
        <Border.Shadow>
            <Shadow Brush="{StaticResource Gray200}"
                    Offset="0,2"
                    Radius="6"
                    Opacity="0.25" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="0">

            <!-- Image Area -->
            <Grid HeightRequest="100"
                  BackgroundColor="{StaticResource Gray100}">
                <Image Source="{Binding ImageSource, Source={x:Reference This}}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"
                       AutomationId="BeverageImage" />

                <!-- Category Badge Overlay -->
                <Border StrokeShape="RoundRectangle 6"
                        BackgroundColor="{StaticResource Primary}"
                        Padding="6,3"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="8">
                    <Label Text="{Binding Category, Source={x:Reference This}}"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="{StaticResource White}" />
                </Border>

                <!-- Favorite Icon -->
                <Label Text="{Binding IsFavorite, Source={x:Reference This}}"
                       FontSize="18"
                       TextColor="{StaticResource Accent}"
                       HorizontalOptions="End"
                       VerticalOptions="Start"
                       Margin="0,8,8,0">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsFavorite, Source={x:Reference This}}"
                                     Value="True">
                            <Setter Property="Text" Value="♥" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsFavorite, Source={x:Reference This}}"
                                     Value="False">
                            <Setter Property="Text" Value="♡" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Grid>

            <!-- Text Area -->
            <VerticalStackLayout Padding="10"
                                 Spacing="4">
                <Label Text="{Binding BeverageName, Source={x:Reference This}}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       LineBreakMode="TailTruncation" />

                <Label Text="{Binding Origin, Source={x:Reference This}}"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}"
                       LineBreakMode="TailTruncation" />

                <!-- Tags -->
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Tags, Source={x:Reference This}}"
                                       Spacing="4"
                                       Margin="0,2,0,0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="{x:Null}">
                            <Border StrokeShape="RoundRectangle 6"
                                    BackgroundColor="{StaticResource PrimaryLight}"
                                    Padding="4,2">
                                <Label Text="{Binding .}"
                                       FontSize="10"
                                       TextColor="{StaticResource PrimaryDark}" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Border>
</ContentView>
