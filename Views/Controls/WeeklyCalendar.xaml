<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.Controls.WeeklyCalendar"
             x:Name="This">

    <Border StrokeShape="RoundRectangle 12"
            BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource Gray200}"
            Padding="16"
            Margin="0,4">
        <Border.Shadow>
            <Shadow Brush="{StaticResource Gray200}"
                    Offset="0,2"
                    Radius="8"
                    Opacity="0.3" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="10">

            <!-- Week Day Headers -->
            <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                  HorizontalOptions="Fill">
                <Label Grid.Column="0" Text="一" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Grid.Column="1" Text="二" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Grid.Column="2" Text="三" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Grid.Column="3" Text="四" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Grid.Column="4" Text="五" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Grid.Column="5" Text="六" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                <Label Grid.Column="6" Text="日" FontSize="12" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
            </Grid>

            <!-- Date Buttons Row -->
            <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                  HorizontalOptions="Fill"
                  x:Name="DatesGrid">
                <!-- Date 1 -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn0"
                            Text="1"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_0" />
                    <Border x:Name="Dot0" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>

                <!-- Date 2 -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn1"
                            Text="2"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_1" />
                    <Border x:Name="Dot1" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>

                <!-- Date 3 -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn2"
                            Text="3"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_2" />
                    <Border x:Name="Dot2" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>

                <!-- Date 4 -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn3"
                            Text="4"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_3" />
                    <Border x:Name="Dot3" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>

                <!-- Date 5 -->
                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn4"
                            Text="5"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_4" />
                    <Border x:Name="Dot4" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>

                <!-- Date 6 -->
                <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn5"
                            Text="6"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_5" />
                    <Border x:Name="Dot5" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>

                <!-- Date 7 -->
                <VerticalStackLayout Grid.Column="6" HorizontalOptions="Center" Spacing="2">
                    <Button x:Name="DateBtn6"
                            Text="7"
                            FontSize="14"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            Padding="0"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            Clicked="OnDateClicked"
                            AutomationId="DateButton_6" />
                    <Border x:Name="Dot6" StrokeShape="RoundRectangle 2.5"
                             WidthRequest="5"
                             HeightRequest="5"
                             BackgroundColor="{StaticResource Primary}"
                             HorizontalOptions="Center"
                             IsVisible="False" />
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </Border>
</ContentView>
