<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.EncyclopediaPage"
             xmlns:viewmodel="clr-namespace:TasteNote.ViewModels"
             xmlns:converter="clr-namespace:TasteNote.Converters"
             x:DataType="viewmodel:EncyclopediaViewModel"
             Title="饮品百科"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converter:StringToUriConverter x:Key="StringToUriConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="0">

        <!-- Search Bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*"
              Padding="16,12,16,0">
            <Frame BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource PrimaryLight}"
                   CornerRadius="12"
                   Padding="0"
                   HasShadow="False"
                   HeightRequest="44">
                <Grid ColumnDefinitions="Auto,*"
                      Padding="12,0">
                    <Label Text="🔍"
                           FontSize="16"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Text="{Binding SearchText}"
                           Placeholder="搜索饮品..."
                           FontSize="14"
                           BackgroundColor="Transparent"
                           ReturnCommand="{Binding SearchCommand}"
                           AutomationId="SearchEntry"
                           SemanticProperties.Hint="搜索饮品百科" />
                </Grid>
            </Frame>
        </Grid>

        <!-- Category Filter -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="16,12,16,0">
            <HorizontalStackLayout Spacing="8"
                                   BindableLayout.ItemsSource="{Binding Categories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="{x:Null}">
                        <Button Text="{Binding .}"
                                FontSize="13"
                                Padding="16,8"
                                HeightRequest="36"
                                CornerRadius="18"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                TextColor="{StaticResource Primary}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:EncyclopediaViewModel}}, Path=SelectCategoryCommand}"
                                CommandParameter="{Binding .}"
                                AutomationId="CategoryButton" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Beverage Grid -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadDataCommand}"
                     IsRefreshing="{Binding IsRefreshing}"
                     Margin="0,8,0,0">
            <CollectionView x:Name="BeverageListView"
                            ItemsSource="{Binding Beverages}"
                            SelectionMode="None"
                            Margin="16,0,16,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Span="2"
                                     Orientation="Vertical"
                                     HorizontalItemSpacing="12"
                                     VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="{x:Null}">
                        <Border BackgroundColor="{StaticResource Surface}"
                                StrokeShape="RoundRectangle 14"
                                StrokeThickness="0"
                                Padding="0">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource TextSecondary}"
                                        Offset="0,3"
                                        Radius="10"
                                        Opacity="0.1" />
                            </Border.Shadow>

                            <VerticalStackLayout>
                                <!-- Image Area with Overlays -->
                                <Grid HeightRequest="100">
                                    <Border StrokeShape="RoundRectangle 14,14,0,0"
                                            BackgroundColor="{StaticResource PrimaryLight}"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Fill">
                                        <Image Source="{Binding ImagePath, Converter={StaticResource StringToUriConverter}}"
                                               Aspect="AspectFill"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill" />
                                    </Border>

                                    <!-- Category Badge -->
                                    <Border BackgroundColor="#CC000000"
                                            StrokeShape="RoundRectangle 6"
                                            Padding="6,2"
                                            HorizontalOptions="Start"
                                            VerticalOptions="Start"
                                            Margin="8,8,0,0">
                                        <Label Text="{Binding Category}"
                                               FontSize="10"
                                               TextColor="White" />
                                    </Border>

                                    <!-- Favorite Icon -->
                                    <Label Text="❤️"
                                           FontSize="16"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="0,8,8,0"
                                           IsVisible="{Binding IsFavorite}" />
                                </Grid>

                                <!-- Info -->
                                <VerticalStackLayout Padding="10,8,10,10"
                                                     Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Origin}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:EncyclopediaViewModel}}, Path=GoToDetailCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
