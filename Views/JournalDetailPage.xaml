<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.JournalDetailPage"
             xmlns:viewmodel="clr-namespace:TasteNote.ViewModels"
             x:DataType="viewmodel:JournalDetailViewModel"
             Title="品鉴详情"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Top Image Area -->
                <Grid HeightRequest="250"
                      x:Name="ImageArea">
                    <!-- Error / Placeholder -->
                    <Border BackgroundColor="#E0E0E0"
                            StrokeShape="RoundRectangle 0,0,24,24"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">
                        <Label Text="暂无图片"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Actual Image -->
                    <Image Source="{Binding ImageUrl}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />

                    <!-- Back Button -->
                    <Border x:Name="BackButton"
                            BackgroundColor="#80000000"
                            StrokeShape="RoundRectangle 20"
                            WidthRequest="40"
                            HeightRequest="40"
                            HorizontalOptions="Start"
                            VerticalOptions="Start"
                            Margin="16,40,0,0">
                        <Label Text="←"
                               FontSize="20"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"
                                                  AutomationId="BackButton" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Favorite Button -->
                    <Border x:Name="FavoriteButton"
                            BackgroundColor="#80000000"
                            StrokeShape="RoundRectangle 20"
                            WidthRequest="40"
                            HeightRequest="40"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,40,16,0">
                        <Label Text="{Binding FavoriteIcon}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}"
                                                  AutomationId="FavoriteButton"
                                                  SemanticProperties.Hint="收藏或取消收藏" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Content Area -->
                <VerticalStackLayout Padding="20,20,20,0"
                                     Spacing="16">

                    <!-- Title + Category -->
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="{Binding Title}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 10"
                                Padding="10,4"
                                VerticalOptions="Center">
                            <Label Text="{Binding Category}"
                                   FontSize="12"
                                   TextColor="{StaticResource Primary}" />
                        </Border>
                    </Grid>

                    <!-- Star Rating -->
                    <HorizontalStackLayout Spacing="4"
                                           x:Name="StarRating">
                        <Label Text="{Binding Star1}" FontSize="24" />
                        <Label Text="{Binding Star2}" FontSize="24" />
                        <Label Text="{Binding Star3}" FontSize="24" />
                        <Label Text="{Binding Star4}" FontSize="24" />
                        <Label Text="{Binding Star5}" FontSize="24" />
                    </HorizontalStackLayout>

                    <!-- Location -->
                    <HorizontalStackLayout Spacing="6"
                                           x:Name="LocationRow">
                        <Label Text="📍"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Text="{Binding Location}"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource PrimaryLight}"
                             Margin="0,4" />

                    <!-- Flavor Tags -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="风味标签"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <FlexLayout Wrap="Wrap"
                                    AlignItems="Start"
                                    JustifyContent="Start"
                                    BindableLayout.ItemsSource="{Binding FlavorTags}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border BackgroundColor="{StaticResource AccentLight}"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,5"
                                            Margin="0,0,8,6">
                                        <Label Text="{Binding .}"
                                               FontSize="13"
                                               TextColor="{StaticResource Accent}" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>

                    <!-- Notes Section -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="品鉴笔记"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding Notes}"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               LineHeight="1.6"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Voice Note Section -->
                    <Border x:Name="VoiceNoteSection"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            Padding="14"
                            IsVisible="{Binding HasVoiceNote}">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <Button x:Name="PlayVoiceButton"
                                    Text="{Binding VoicePlayIcon}"
                                    FontSize="20"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    CornerRadius="22"
                                    Padding="0"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource Surface}"
                                    Command="{Binding PlayVoiceCommand}"
                                    AutomationId="PlayVoiceButton"
                                    SemanticProperties.Hint="播放语音笔记" />
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="语音笔记"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding VoiceDuration}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Spacer for bottom bar -->
                    <BoxView HeightRequest="80"
                             BackgroundColor="Transparent" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Surface}"
                StrokeShape="RoundRectangle 20,20,0,0"
                Padding="16,12,16,20"
                HorizontalOptions="Fill"
                VerticalOptions="End">
            <Border.Shadow>
                <Shadow Brush="{StaticResource TextSecondary}"
                        Offset="0,-4"
                        Radius="12"
                        Opacity="0.1" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">
                <Button x:Name="TTSButton"
                        Grid.Column="0"
                        Text="{Binding TTSButtonText}"
                        FontSize="12"
                        TextColor="{StaticResource Primary}"
                        BackgroundColor="{StaticResource PrimaryLight}"
                        CornerRadius="12"
                        Command="{Binding ToggleTTSCommand}"
                        AutomationId="TTSButton"
                        SemanticProperties.Hint="朗读笔记" />

                <Button x:Name="VoiceNoteButton"
                        Grid.Column="1"
                        Text="🎤 语音笔记"
                        FontSize="12"
                        TextColor="{StaticResource Primary}"
                        BackgroundColor="{StaticResource PrimaryLight}"
                        CornerRadius="12"
                        Command="{Binding RecordVoiceCommand}"
                        AutomationId="VoiceNoteButton"
                        SemanticProperties.Hint="录制语音笔记" />

                <Button x:Name="EditButton"
                        Grid.Column="2"
                        Text="编辑"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Surface}"
                        BackgroundColor="{StaticResource Primary}"
                        CornerRadius="12"
                        Command="{Binding EditCommand}"
                        AutomationId="EditButton"
                        SemanticProperties.Hint="编辑品鉴记录" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
