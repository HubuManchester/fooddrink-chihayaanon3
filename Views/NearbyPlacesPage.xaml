<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.NearbyPlacesPage"
             xmlns:viewmodel="clr-namespace:TasteNote.ViewModels"
             x:DataType="viewmodel:NearbyPlacesViewModel"
             xmlns:model="clr-namespace:TasteNote.Models"
             xmlns:converters="clr-namespace:TasteNote.Converters"
             Title="附近店铺"
             BackgroundColor="{StaticResource Background}">

    <ScrollView Padding="16,8"
                VerticalOptions="Fill">
        <VerticalStackLayout Spacing="16">

            <!-- Back Button -->
            <HorizontalStackLayout>
                <Button Text="← 返回"
                        FontSize="14"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        Command="{Binding GoBackCommand}"
                        AutomationId="BackButton"
                        SemanticProperties.Hint="返回上一页" />
            </HorizontalStackLayout>

            <!-- Current Location Card -->
            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray200}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Gray200}"
                            Offset="0,2"
                            Radius="8"
                            Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="当前位置"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding CoordinatesText}"
                           FontSize="12"
                           FontFamily="Courier New"
                           TextColor="{StaticResource TextSecondary}"
                           AutomationId="CoordinatesLabel" />
                    <Label Text="{Binding LocationStatus}"
                           FontSize="12"
                           TextColor="{StaticResource Primary}"
                           AutomationId="LocationStatusLabel" />
                </VerticalStackLayout>
            </Border>

            <!-- Stats -->
            <Label FontSize="14"
                   TextColor="{StaticResource TextSecondary}">
                <Label.Text>
                    <MultiBinding StringFormat="附近共 {0} 家店铺（模拟数据）">
                        <Binding Path="Places.Count" />
                    </MultiBinding>
                </Label.Text>
            </Label>

            <!-- CollectionView of Nearby Places -->
            <CollectionView ItemsSource="{Binding Places}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:PlaceInfo">
                        <Border StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource Gray200}"
                                Margin="0,4"
                                Padding="12">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource Gray200}"
                                        Offset="0,2"
                                        Radius="6"
                                        Opacity="0.25" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:NearbyPlacesViewModel}}, Path=OpenMapCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <!-- Type Icon -->
                                <Border Grid.RowSpan="2"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Type}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryDark}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Name -->
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation" />

                                <!-- Address -->
                                <Label Grid.Column="1"
                                       Grid.Row="1"
                                       Text="{Binding Address}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"
                                       LineBreakMode="TailTruncation" />

                                <!-- Distance Badge -->
                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{StaticResource Primary}"
                                        Padding="8,4"
                                        HorizontalOptions="End"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding DistanceText}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}" />
                                </Border>

                                <!-- Coordinates -->
                                <Label Grid.Column="2"
                                       Grid.Row="1"
                                       Text="{Binding CoordinatesText}"
                                       FontSize="10"
                                       FontFamily="Courier New"
                                       TextColor="{StaticResource Gray400}"
                                       LineBreakMode="TailTruncation"
                                       HorizontalOptions="End"
                                       VerticalOptions="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
