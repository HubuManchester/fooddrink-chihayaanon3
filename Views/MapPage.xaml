<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TasteNote.Views.MapPage"
             xmlns:viewmodel="clr-namespace:TasteNote.ViewModels"
             x:DataType="viewmodel:MapViewModel"
             xmlns:model="clr-namespace:TasteNote.Models"
             xmlns:converters="clr-namespace:TasteNote.Converters"
             Title="地图"
             BackgroundColor="{StaticResource Background}">

    <ScrollView Padding="16,8"
                VerticalOptions="Fill">
        <VerticalStackLayout Spacing="16">

            <!-- Current Location Card -->
            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray200}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Gray200}"
                            Offset="0,2"
                            Radius="8"
                            Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="当前位置"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding CoordinatesText}"
                           FontSize="12"
                           FontFamily="Courier New"
                           TextColor="{StaticResource TextSecondary}"
                           AutomationId="CoordinatesLabel" />
                    <Label Text="{Binding CompassHeading}"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           AutomationId="CompassLabel" />
                    <Label Text="{Binding LocationStatus}"
                           FontSize="12"
                           TextColor="{StaticResource Primary}"
                           AutomationId="LocationStatusLabel" />
                </VerticalStackLayout>
            </Border>

            <!-- Stats -->
            <Label FontSize="14"
                   TextColor="{StaticResource TextSecondary}">
                <Label.Text>
                    <MultiBinding StringFormat="已收藏 {0} 个地点">
                        <Binding Path="Places.Count" />
                    </MultiBinding>
                </Label.Text>
            </Label>

            <!-- CollectionView of Places -->
            <CollectionView ItemsSource="{Binding Places}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:FavoritePlace">
                        <Border StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource Gray200}"
                                Margin="0,4"
                                Padding="12">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource Gray200}"
                                        Offset="0,2"
                                        Radius="6"
                                        Opacity="0.25" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MapViewModel}}, Path=OpenMapCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <!-- Type Icon -->
                                <Border Grid.RowSpan="2"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Category}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource PrimaryDark}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Name -->
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="TailTruncation" />

                                <!-- Address + LastVisitDate -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Grid.Row="1"
                                                     Spacing="2">
                                    <Label Text="{Binding Address}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding LastVisitDate}"
                                           FontSize="11"
                                           TextColor="{StaticResource Gray400}" />
                                </VerticalStackLayout>

                                <!-- Rating Stars + Coordinates -->
                                <VerticalStackLayout Grid.Column="2"
                                                     HorizontalOptions="End"
                                                     Spacing="2">
                                    <HorizontalStackLayout HorizontalOptions="End"
                                                           Spacing="1">
                                        <Label Text="{Binding Rating, Converter={converters:RatingToStarConverter StarIndex=1}, ConverterParameter=1}"
                                               FontSize="11" />
                                        <Label Text="{Binding Rating, Converter={converters:RatingToStarConverter StarIndex=2}, ConverterParameter=2}"
                                               FontSize="11" />
                                        <Label Text="{Binding Rating, Converter={converters:RatingToStarConverter StarIndex=3}, ConverterParameter=3}"
                                               FontSize="11" />
                                        <Label Text="{Binding Rating, Converter={converters:RatingToStarConverter StarIndex=4}, ConverterParameter=4}"
                                               FontSize="11" />
                                        <Label Text="{Binding Rating, Converter={converters:RatingToStarConverter StarIndex=5}, ConverterParameter=5}"
                                               FontSize="11" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding CoordinatesText}"
                                           FontSize="10"
                                           FontFamily="Courier New"
                                           TextColor="{StaticResource Gray400}"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Bottom Buttons -->
            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Gray200}"
                    Padding="12"
                    Margin="0,8">
                <HorizontalStackLayout 
                                       Spacing="8"
                                       HorizontalOptions="Center">
                    <Button Text="附近店铺"
                            FontSize="13"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            TextColor="{StaticResource PrimaryDark}"
                            Command="{Binding NavigateNearbyCommand}"
                            AutomationId="NearbyButton"
                            SemanticProperties.Hint="查看附近店铺" />
                    <Button Text="添加地点"
                            FontSize="13"
                            Command="{Binding AddPlaceCommand}"
                            AutomationId="AddPlaceButton"
                            SemanticProperties.Hint="添加新地点" />
                    <Button Text="我的口味档案"
                            FontSize="13"
                            BackgroundColor="{StaticResource AccentLight}"
                            TextColor="{StaticResource Accent}"
                            Command="{Binding NavigateTasteProfileCommand}"
                            AutomationId="TasteProfileButton"
                            SemanticProperties.Hint="查看口味档案" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
